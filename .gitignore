/target
# The sealed secret instance (contains k). Never committed; regenerated per run
# from $ECDLP_SEED. Only instance.public.json (no k) is safe to publish.
instance.secret.json
*.tmp
# Scaling-track candidate output (transient, per run). The COMMITTED record is
# scaling.baseline.json; a run writes its candidate to scaling.json, which is
# gated against the baseline by tools/beats_curve.py and only promoted on a win.
/scaling.json
# Sage preparsed artifacts and stray research-track outputs at the repo root
# (the curated first_blood/instance_public_*.json ARE committed).
*.sage.py
/instance_public_*.json
# macOS junk (the volume writes AppleDouble forks).
._*
.DS_Store
# Python bytecode (site/build.py imports first_blood/verify_first_blood.py).
__pycache__/
*.pyc
